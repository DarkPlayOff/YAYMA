# Maintainer: Your Name <your.email@example.com>
pkgname=yayma-bin
_pkgname=yayma
pkgver=@VERSION@
pkgrel=1
pkgdesc="Yet Another Yandex Music Client"
arch=('x86_64')
url="https://github.com/@REPO@"
license=('GPL-3.0-or-later')
depends=('gtk3' 'libsecret' 'libsoup3' 'webkit2gtk-4.1' 'alsa-lib' 'libayatana-appindicator' 'dbus')
makedepends=('imagemagick')
provides=('yayma')
conflicts=('yayma')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/@REPO@/releases/download/v${pkgver}/yayma-linux-x64-${pkgver}.tar.gz"
        "LICENSE::https://raw.githubusercontent.com/@REPO@/v${pkgver}/LICENSE"
        "io.github.darkplayoff.yayma.desktop::https://raw.githubusercontent.com/@REPO@/v${pkgver}/packaging/linux/io.github.darkplayoff.yayma.desktop")
sha256sums=('@TARBALL_SHA_X64@'
            '@LICENSE_SHA@'
            '@DESKTOP_SHA@')

package() {
  install -dm755 "${pkgdir}/opt/${_pkgname}"
  cp -r "${srcdir}/data" "${srcdir}/lib" "${pkgdir}/opt/${_pkgname}/"
  install -Dm755 "${srcdir}/${_pkgname}" "${pkgdir}/opt/${_pkgname}/${_pkgname}"

  install -dm755 "${pkgdir}/usr/bin"
  ln -s "/opt/${_pkgname}/${_pkgname}" "${pkgdir}/usr/bin/${_pkgname}"

  install -Dm644 "${srcdir}/io.github.darkplayoff.yayma.desktop" "${pkgdir}/usr/share/applications/io.github.darkplayoff.yayma.desktop"

  magick "${srcdir}/data/flutter_assets/assets/icons/logo.webp" -resize 256x256 "${srcdir}/icon.png"
  install -Dm644 "${srcdir}/icon.png" "${pkgdir}/usr/share/icons/hicolor/256x256/apps/io.github.darkplayoff.yayma.png"

  install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
